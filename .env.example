# PostgreSQL
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=data_quality_db
DB_DRIVER=postgresql+psycopg2

# Source extraction database
SOURCE_DB_TYPE=postgres
DATA_SOURCE_TYPE=postgres
SOURCE_DB_USER=postgres
SOURCE_DB_PASSWORD=postgres
SOURCE_DB_HOST=localhost
SOURCE_DB_PORT=5432
SOURCE_DB_NAME=data_quality_db
SOURCE_DB_DRIVER=postgresql+psycopg2

# Monitoring results database
MONITOR_DB_USER=postgres
MONITOR_DB_PASSWORD=postgres
MONITOR_DB_HOST=localhost
MONITOR_DB_PORT=5432
MONITOR_DB_NAME=data_quality_db
MONITOR_DB_DRIVER=postgresql+psycopg2
SKIP_PREFLIGHT_CHECK=false

# Optional Amazon Redshift source extraction
REDSHIFT_HOST=your-redshift-cluster.amazonaws.com
REDSHIFT_PORT=5439
REDSHIFT_DB=analytics
REDSHIFT_USER=redshift_user
REDSHIFT_PASSWORD=redshift_password
REDSHIFT_SCHEMA=public

# Optional Snowflake source extraction
SNOWFLAKE_ACCOUNT=your_account
SNOWFLAKE_USER=your_user
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_WAREHOUSE=your_warehouse
SNOWFLAKE_DATABASE=your_database
SNOWFLAKE_SCHEMA=PUBLIC

# Optional BigQuery source extraction
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json
BIGQUERY_PROJECT_ID=your_project_id
BIGQUERY_DATASET=your_dataset

# Streamlit dashboard authentication
DASHBOARD_AUTH_ENABLED=true
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change_me
# Optional: set DASHBOARD_PASSWORD_HASH to a SHA-256 hash to avoid plain text.
# DASHBOARD_PASSWORD_HASH=

# Enterprise dashboard branding
APP_NAME=Automated Data Quality Monitoring System
COMPANY_NAME=Your Company
DASHBOARD_TITLE=Data Quality Command Center
DASHBOARD_ICON=📊
ENVIRONMENT_NAME=Development
DASHBOARD_THEME=light
DEMO_BRANDING_MODE=false
BRAND_PRIMARY_COLOR=#1E3A8A
BRAND_SECONDARY_COLOR=#0F172A
BRAND_ACCENT_COLOR=#2563EB
BRAND_SUCCESS_COLOR=#16A34A
BRAND_WARNING_COLOR=#F59E0B
BRAND_ERROR_COLOR=#DC2626
BRAND_LOGO_PATH=ui/assets/logo.png
BRAND_FAVICON_PATH=ui/assets/favicon.png

# Email notifications
EMAIL_NOTIFICATIONS_ENABLED=false
EMAIL_PROVIDER=mailtrap
ALERT_RECIPIENTS=receiver@example.com

# Mailtrap Email API
MAILTRAP_API_TOKEN=your_mailtrap_api_token
MAILTRAP_SENDER_EMAIL=hello@demomailtrap.co
MAILTRAP_SENDER_NAME=Data Quality Monitor

# Slack notifications
SLACK_NOTIFICATIONS_ENABLED=false
SLACK_WEBHOOK_URL=your_slack_webhook_url

# Microsoft Teams notifications
TEAMS_NOTIFICATIONS_ENABLED=false
TEAMS_WEBHOOK_URL=your_teams_webhook_url

# Optional SMTP fallback
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USE_STARTTLS=true
SMTP_USER=your_smtp_username
SMTP_PASSWORD=your_smtp_password
EMAIL_FROM_NAME=Data Quality Monitor

# Optional Airflow orchestration
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_WEBSERVER_SECRET_KEY=change_this_airflow_secret
DQ_PROJECT_ROOT=/opt/airflow/project
DQ_PYTHON_BIN=python
DQ_SEED_SAMPLE_DATA=false
