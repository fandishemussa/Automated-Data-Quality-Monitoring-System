# PostgreSQL
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=data_quality_db
DB_DRIVER=postgresql+psycopg2

# Email notifications
EMAIL_NOTIFICATIONS_ENABLED=false
EMAIL_PROVIDER=mailtrap
ALERT_RECIPIENTS=receiver@example.com

# Mailtrap Email API
MAILTRAP_API_TOKEN=your_mailtrap_api_token
MAILTRAP_SENDER_EMAIL=hello@demomailtrap.co
MAILTRAP_SENDER_NAME=Data Quality Monitor

# Optional SMTP fallback
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USE_STARTTLS=true
SMTP_USER=your_smtp_username
SMTP_PASSWORD=your_smtp_password
EMAIL_FROM_NAME=Data Quality Monitor

# Optional Airflow orchestration
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_WEBSERVER_SECRET_KEY=change_this_airflow_secret
DQ_PROJECT_ROOT=/opt/airflow/project
DQ_PYTHON_BIN=python
DQ_SEED_SAMPLE_DATA=false
